# ── Vercel project env vars (Settings → Environment Variables) ──
# Used by api/upload-blueprint.js to commit uploaded blueprints to GitHub.

# Fine-grained Personal Access Token with "Contents: Read and write" on the repo below.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# The repo that stores blueprints (and, if you commit data.js, the app itself).
GITHUB_REPO=your-org/your-repo

# Optional
GITHUB_BRANCH=main
GITHUB_BLUEPRINT_DIR=blueprints

# Optional shared secret. If set, the uploader must send a matching
# "X-Upload-Token" header (gate the public upload endpoint against abuse).
# UPLOAD_TOKEN=some-long-random-string
